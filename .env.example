# Mineflayer bridge URL (default: http://localhost:3001)
KASUKABE_BRIDGE_URL=http://localhost:3001

# RCON connection (Paper server)
# CRAFTSMEN_RCON_PASSWORD is REQUIRED and must match rcon.password in server.properties.
# Pick any non-empty string; the server will reject connections without it.
CRAFTSMEN_RCON_HOST=127.0.0.1
CRAFTSMEN_RCON_PORT=25575
CRAFTSMEN_RCON_PASSWORD=<change-me>

# Default build origin if not specified
KASUKABE_DEFAULT_ORIGIN=100,64,200
